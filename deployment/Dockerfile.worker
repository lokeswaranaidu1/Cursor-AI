# Dockerfile for HomeCenter Batch Processing Worker
FROM python:3.11-slim

# Set working directory
WORKDIR /app

# Set environment variables
ENV PYTHONPATH=/app
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    libc6-dev \
    libpq-dev \
    curl \
    default-jre \
    && rm -rf /var/lib/apt/lists/*

# Install Apache Spark (for PySpark)
ENV SPARK_VERSION=3.5.0
ENV HADOOP_VERSION=3
RUN curl -sL https://archive.apache.org/dist/spark/spark-${SPARK_VERSION}/spark-${SPARK_VERSION}-bin-hadoop${HADOOP_VERSION}.tgz | \
    tar -xz -C /opt/ && \
    mv /opt/spark-${SPARK_VERSION}-bin-hadoop${HADOOP_VERSION} /opt/spark

ENV SPARK_HOME=/opt/spark
ENV PATH=$PATH:$SPARK_HOME/bin:$SPARK_HOME/sbin

# Create non-root user
RUN useradd --create-home --shell /bin/bash worker

# Copy requirements and install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install additional ML dependencies
RUN pip install --no-cache-dir \
    apache-airflow[postgres,aws]==2.8.0 \
    mlflow==2.8.1 \
    great-expectations==0.18.8

# Copy application code
COPY src/ ./src/
COPY *.py ./

# Create directories and set permissions
RUN mkdir -p /app/logs /app/tmp /app/data && \
    chown -R worker:worker /app && \
    chown -R worker:worker /opt/spark

# Switch to non-root user
USER worker

# Set Spark configuration
ENV PYSPARK_PYTHON=python3
ENV PYSPARK_DRIVER_PYTHON=python3

# Expose Spark UI port
EXPOSE 4040

# Default command (can be overridden)
CMD ["python", "-m", "src.batch_processing.training_pipeline"]